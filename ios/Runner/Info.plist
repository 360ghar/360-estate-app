<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>360 Estate</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>estate_app</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>
	<key>CFBundleSignature</key>
	<string>????</string>
	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.the360ghar.estateapp</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>com.the360ghar.estateapp</string>
			</array>
		</dict>
		<dict>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLName</key>
			<string>com.the360ghar.estateapp.deeplink</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>estate360</string>
			</array>
		</dict>
		<!-- Google Sign-In: add a URL type whose scheme is the REVERSED iOS
		     OAuth client id (e.g. com.googleusercontent.apps.XXXXX-YYYYY).
		     Uncomment and fill in once GOOGLE_IOS_CLIENT_ID is provisioned
		     (Phase 0). Do not remove the schemes above.
		<dict>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLName</key>
			<string>com.the360ghar.estateapp.google</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>com.googleusercontent.apps.REVERSED_IOS_CLIENT_ID</string>
			</array>
		</dict>
		-->
	</array>
	<!-- Camera permission for property photos -->
	<key>NSCameraUsageDescription</key>
	<string>360 Estate needs camera access to take photos for property listings.</string>
	<!-- Photo library permission for image selection -->
	<key>NSPhotoLibraryUsageDescription</key>
	<string>360 Estate needs photo library access to select images for property listings.</string>
	<!-- Photo library add permission for saving photos -->
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>360 Estate needs permission to save photos to your library.</string>
	<!-- Location permission for property tagging and discovery -->
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>360 Estate needs your location to tag properties with their position and help you discover nearby listings.</string>
	<!-- Location permission for background location-based features -->
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>360 Estate needs your location to provide location-based features and notifications.</string>
	<!-- Microphone permission for video tours -->
	<key>NSMicrophoneUsageDescription</key>
	<string>360 Estate needs microphone access for video tours.</string>
	<key>NSUserTrackingUsageDescription</key>
	<string>We use tracking to provide personalized property recommendations and measure the effectiveness of our advertising.</string>
	<key>UIBackgroundModes</key>
	<array>
		<string>remote-notification</string>
	</array>
</dict>
</plist>
