# Copy this file to `.env` and fill in values.
# This file is bundled into the app as an asset when referenced as `.env`.

APP_ENV=dev

API_BASE_URL=https://api.360ghar.com/api/v1

SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=

ENABLE_DEBUG_LOGS=true
ENABLE_CRASH_REPORTING=false
ENABLE_APPLICATIONS_MODULE=true
ENABLE_PUBLIC_APPLICATIONS=true

GOOGLE_PLACES_API_KEY=

# Google Sign-In (native ID-token flow). Obtain from Google Cloud Console.
# GOOGLE_WEB_CLIENT_ID is used as the Android serverClientId and is required
# for Supabase to validate the returned ID token. GOOGLE_IOS_CLIENT_ID is the
# iOS OAuth client id (also append its reversed form to ios/Runner/Info.plist).
# GOOGLE_WEB_CLIENT_ID=
# GOOGLE_IOS_CLIENT_ID=

# Override the Google OAuth redirect deep link URL.
# Default: com.the360ghar.estateapp://login-callback
# AUTH_REDIRECT_URL=
