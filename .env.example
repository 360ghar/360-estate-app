# Copy this file to `.env` and fill in values.
# This file is bundled into the app as an asset when referenced as `.env`.

APP_ENV=dev

# Backend API (REQUIRED - this is the primary data source)
API_BASE_URL=https://api.example.com

# Supabase (REQUIRED for authentication)
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key

# USE_MOCK_API: Optional fallback for local testing WITHOUT backend connection
# DEFAULT: false (API-first architecture)
# Set to 'true' ONLY for isolated dev testing without backend access
# MUST NEVER be 'true' in production builds
USE_MOCK_API=false

ENABLE_DEBUG_LOGS=true
ENABLE_CRASH_REPORTING=false
ENABLE_PUBLIC_APPLICATIONS=true


